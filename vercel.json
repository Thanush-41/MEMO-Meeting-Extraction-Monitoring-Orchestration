{
  "version": 2,
  "builds": [
    { "src": "api/process.py", "use": "@vercel/python" },
    { "src": "dashboard/index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/process", "dest": "api/process.py", "methods": ["POST", "OPTIONS"] },
    { "src": "/(.*)", "dest": "dashboard/index.html" }
  ]
}